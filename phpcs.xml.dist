<?xml version="1.0"?>
<ruleset name="Enable Abilities for MCP">
	<description>WPCS ruleset for Enable Abilities for MCP plugin.</description>

	<!-- Scan these files -->
	<file>enable-abilities-for-mcp.php</file>
	<file>uninstall.php</file>
	<file>includes/abilities.php</file>
	<file>includes/admin.php</file>
	<file>includes/auth.php</file>

	<!-- Exclude vendor -->
	<exclude-pattern>vendor/*</exclude-pattern>

	<!-- Use WordPress coding standard -->
	<rule ref="WordPress">
		<!-- Allow any file naming convention (plugin uses standard WP naming) -->
		<exclude name="WordPress.Files.FileName"/>
		<!--
			permission_callback closures in the Abilities API require the $args
			parameter in their signature even when not used in the body.
		-->
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter"/>
		<!--
			tax_query, meta_query, meta_key are required for CPT, TEC and WC
			filtering. These are known slow queries, acknowledged and acceptable.
		-->
		<exclude name="WordPress.DB.SlowDBQuery"/>
	</rule>

	<!-- Declare WooCommerce custom capabilities -->
	<rule ref="WordPress.WP.Capabilities">
		<properties>
			<property name="custom_capabilities" type="array">
				<element value="edit_products"/>
				<element value="edit_others_products"/>
				<element value="publish_products"/>
				<element value="read_private_products"/>
				<element value="delete_products"/>
				<element value="edit_shop_orders"/>
				<element value="edit_others_shop_orders"/>
				<element value="publish_shop_orders"/>
				<element value="read_private_shop_orders"/>
				<element value="delete_shop_orders"/>
				<element value="edit_tribe_events"/>
				<element value="edit_others_tribe_events"/>
				<element value="publish_tribe_events"/>
				<element value="read_private_tribe_events"/>
				<element value="delete_tribe_events"/>
			</property>
		</properties>
	</rule>

</ruleset>
