#: enable-abilities-for-mcp.php:71
msgid "Core de WordPress"
msgstr "WordPress Core"

#: enable-abilities-for-mcp.php:72
msgid "Abilities nativas del core de WordPress. Se exponen al MCP con el flag público."
msgstr "Native WordPress core abilities. Exposed to MCP with the public flag."

#: enable-abilities-for-mcp.php:76
msgid "Información del Sitio"
msgstr "Site Information"

#: enable-abilities-for-mcp.php:77
msgid "Datos generales del sitio: nombre, URL, descripción, idioma, zona horaria, versión de WP."
msgstr "General site data: name, URL, description, language, timezone, WP version."

#: enable-abilities-for-mcp.php:80
msgid "Información del Usuario"
msgstr "User Information"

#: enable-abilities-for-mcp.php:81
msgid "Datos del usuario actual: nombre, email, rol, avatar."
msgstr "Current user data: name, email, role, avatar."

#: enable-abilities-for-mcp.php:84
msgid "Información del Entorno"
msgstr "Environment Information"

#: enable-abilities-for-mcp.php:85
msgid "Detalles técnicos: versión de PHP, servidor de BD, tipo de entorno."
msgstr "Technical details: PHP version, database server, environment type."

#: enable-abilities-for-mcp.php:90
msgid "Lectura (Solo Consulta)"
msgstr "Read (Query Only)"

#: enable-abilities-for-mcp.php:91
msgid "Solo consultan datos, no modifican nada. Las más seguras para exponer vía MCP."
msgstr "Query-only operations, no modifications. The safest to expose via MCP."

#: enable-abilities-for-mcp.php:95
#: includes/abilities.php:119
msgid "Obtener Posts"
msgstr "Get Posts"

#: enable-abilities-for-mcp.php:96
msgid "Lista posts con filtros por estado, categoría, cantidad y orden."
msgstr "List posts with filters by status, category, count, and order."

#: enable-abilities-for-mcp.php:99
#: includes/abilities.php:260
msgid "Obtener Post Individual"
msgstr "Get Single Post"

#: enable-abilities-for-mcp.php:100
msgid "Detalle completo de un post por ID, incluyendo contenido, meta datos e imagen destacada."
msgstr "Full post details by ID, including content, metadata, and featured image."

#: enable-abilities-for-mcp.php:103
#: includes/abilities.php:353
msgid "Obtener Categorías"
msgstr "Get Categories"

#: enable-abilities-for-mcp.php:104
msgid "Lista todas las categorías con ID, nombre, slug y cantidad de posts."
msgstr "List all categories with ID, name, slug, and post count."

#: enable-abilities-for-mcp.php:107
#: includes/abilities.php:417
msgid "Obtener Etiquetas"
msgstr "Get Tags"

#: enable-abilities-for-mcp.php:108
msgid "Lista todas las etiquetas (tags) con ID, nombre, slug y cantidad de posts."
msgstr "List all tags with ID, name, slug, and post count."

#: enable-abilities-for-mcp.php:111
#: includes/abilities.php:485
msgid "Obtener Páginas"
msgstr "Get Pages"

#: enable-abilities-for-mcp.php:112
msgid "Lista páginas del sitio con título, estado y jerarquía."
msgstr "List site pages with title, status, and hierarchy."

#: enable-abilities-for-mcp.php:115
#: includes/abilities.php:566
msgid "Obtener Comentarios"
msgstr "Get Comments"

#: enable-abilities-for-mcp.php:116
msgid "Lista comentarios con filtros por estado, post y cantidad."
msgstr "List comments with filters by status, post, and count."

#: enable-abilities-for-mcp.php:119
#: includes/abilities.php:653
msgid "Obtener Medios"
msgstr "Get Media"

#: enable-abilities-for-mcp.php:120
msgid "Lista archivos de la biblioteca de medios con filtros por tipo."
msgstr "List media library files with type filters."

#: enable-abilities-for-mcp.php:123
#: includes/abilities.php:740
msgid "Obtener Usuarios"
msgstr "Get Users"

#: enable-abilities-for-mcp.php:124
msgid "Lista usuarios del sitio con ID, nombre, email y rol."
msgstr "List site users with ID, name, email, and role."

#: enable-abilities-for-mcp.php:129
msgid "Escritura (Crear y Modificar)"
msgstr "Write (Create & Modify)"

#: enable-abilities-for-mcp.php:130
msgid "Crean o modifican contenido. Requieren permisos apropiados del usuario MCP."
msgstr "Create or modify content. Require appropriate MCP user permissions."

#: enable-abilities-for-mcp.php:135
#: includes/abilities.php:810
msgid "Crear Post"
msgstr "Create Post"

#: enable-abilities-for-mcp.php:136
msgid "Crea un nuevo post con título, contenido, categorías, etiquetas, imagen destacada y más."
msgstr "Create a new post with title, content, categories, tags, featured image, and more."

#: enable-abilities-for-mcp.php:139
#: includes/abilities.php:964
msgid "Actualizar Post"
msgstr "Update Post"

#: enable-abilities-for-mcp.php:140
msgid "Modifica un post existente. Solo actualiza los campos enviados."
msgstr "Modify an existing post. Only updates the fields provided."

#: enable-abilities-for-mcp.php:143
#: includes/abilities.php:1105
msgid "Eliminar Post"
msgstr "Delete Post"

#: enable-abilities-for-mcp.php:144
msgid "Envía un post a la papelera o lo elimina permanentemente."
msgstr "Move a post to trash or permanently delete it."

#: enable-abilities-for-mcp.php:147
#: includes/abilities.php:1173
msgid "Crear Categoría"
msgstr "Create Category"

#: enable-abilities-for-mcp.php:148
msgid "Crea una nueva categoría con nombre, slug, descripción y padre."
msgstr "Create a new category with name, slug, description, and parent."

#: enable-abilities-for-mcp.php:151
#: includes/abilities.php:1256
msgid "Crear Etiqueta"
msgstr "Create Tag"

#: enable-abilities-for-mcp.php:152
msgid "Crea una nueva etiqueta (tag) con nombre, slug y descripción."
msgstr "Create a new tag with name, slug, and description."

#: enable-abilities-for-mcp.php:155
#: includes/abilities.php:1331
msgid "Crear Página"
msgstr "Create Page"

#: enable-abilities-for-mcp.php:156
msgid "Crea una nueva página con título, contenido, estado y página padre."
msgstr "Create a new page with title, content, status, and parent page."

#: enable-abilities-for-mcp.php:159
#: includes/abilities.php:1426
msgid "Moderar Comentario"
msgstr "Moderate Comment"

#: enable-abilities-for-mcp.php:160
msgid "Cambia el estado de un comentario: aprobar, espera, spam o papelera."
msgstr "Change comment status: approve, hold, spam, or trash."

#: enable-abilities-for-mcp.php:163
#: includes/abilities.php:1508
msgid "Subir Imagen desde URL"
msgstr "Upload Image from URL"

#: enable-abilities-for-mcp.php:164
msgid "Descarga una imagen desde una URL externa y la registra en la biblioteca de medios. Retorna el ID del attachment."
msgstr "Download an image from an external URL and register it in the media library. Returns the attachment ID."

#: enable-abilities-for-mcp.php:169
msgid "SEO — Rank Math"
msgstr "SEO — Rank Math"

#: enable-abilities-for-mcp.php:170
msgid "Consulta y actualiza la metadata SEO de Rank Math en posts y páginas."
msgstr "Query and update Rank Math SEO metadata for posts and pages."

#: enable-abilities-for-mcp.php:174
#: includes/abilities.php:1681
msgid "Obtener Metadata Rank Math"
msgstr "Get Rank Math Metadata"

#: enable-abilities-for-mcp.php:175
msgid "Obtiene la metadata SEO de Rank Math de un post o página: título, descripción, keywords, robots, Open Graph y más."
msgstr "Get Rank Math SEO metadata for a post or page: title, description, keywords, robots, Open Graph, and more."

#: enable-abilities-for-mcp.php:178
#: includes/abilities.php:1806
msgid "Actualizar SEO / Focus Keyword de Rank Math"
msgstr "Update SEO / Focus Keyword for Rank Math"

#: enable-abilities-for-mcp.php:179
msgid "Actualiza la palabra clave objetivo (focus keyword), título SEO, descripción, URL canónica, robots y Open Graph de Rank Math."
msgstr "Update the focus keyword, SEO title, description, canonical URL, robots, and Open Graph for Rank Math."

#: enable-abilities-for-mcp.php:184
msgid "Utilidad"
msgstr "Utility"

#: enable-abilities-for-mcp.php:185
msgid "Herramientas auxiliares que complementan el flujo de trabajo."
msgstr "Helper tools that complement the workflow."

#: enable-abilities-for-mcp.php:189
#: includes/abilities.php:2095
msgid "Buscar y Reemplazar"
msgstr "Search and Replace"

#: enable-abilities-for-mcp.php:190
msgid "Busca un texto en el contenido de un post y lo reemplaza por otro."
msgstr "Search for text in a post's content and replace it with another."

#: enable-abilities-for-mcp.php:193
#: includes/abilities.php:2184
msgid "Estadísticas del Sitio"
msgstr "Site Statistics"

#: enable-abilities-for-mcp.php:194
msgid "Resumen del sitio: total de posts, páginas, categorías, tags, comentarios y usuarios."
msgstr "Site summary: total posts, pages, categories, tags, comments, and users."

#: includes/abilities.php:74
msgid "Gestión de Contenido"
msgstr "Content Management"

#: includes/abilities.php:75
msgid "Abilities para crear, leer, actualizar y eliminar contenido del blog."
msgstr "Abilities to create, read, update, and delete blog content."

#: includes/abilities.php:82
msgid "Gestión de Usuarios"
msgstr "User Management"

#: includes/abilities.php:83
msgid "Abilities para consultar información de usuarios del sitio."
msgstr "Abilities to query site user information."

#: includes/abilities.php:91
msgid "Abilities para obtener información general y estadísticas del sitio."
msgstr "Abilities to get general site information and statistics."

#: includes/abilities.php:120
msgid "Obtiene una lista de posts/entradas del blog con filtros opcionales por estado, categoría, cantidad y orden."
msgstr "Get a list of blog posts with optional filters by status, category, count, and order."

#: includes/abilities.php:261
msgid "Obtiene todos los detalles de un post específico por su ID, incluyendo contenido completo, meta datos e imagen destacada."
msgstr "Get all details of a specific post by ID, including full content, metadata, and featured image."

#: includes/abilities.php:354
msgid "Obtiene todas las categorías del blog con su ID, nombre, slug, descripción y cantidad de posts asociados."
msgstr "Get all blog categories with ID, name, slug, description, and associated post count."

#: includes/abilities.php:418
msgid "Obtiene todas las etiquetas (tags) del blog con su ID, nombre, slug y cantidad de posts asociados."
msgstr "Get all blog tags with ID, name, slug, and associated post count."

#: includes/abilities.php:486
msgid "Obtiene las páginas del sitio WordPress con su título, estado, contenido y jerarquía (páginas padre/hijo)."
msgstr "Get WordPress site pages with title, status, content, and hierarchy (parent/child pages)."

#: includes/abilities.php:567
msgid "Obtiene los comentarios del blog con filtros opcionales por estado, post y cantidad. Útil para moderación y análisis."
msgstr "Get blog comments with optional filters by status, post, and count. Useful for moderation and analysis."

#: includes/abilities.php:654
msgid "Obtiene archivos de la biblioteca de medios (imágenes, videos, documentos) con filtros por tipo MIME y búsqueda."
msgstr "Get media library files (images, videos, documents) with MIME type and search filters."

#: includes/abilities.php:741
msgid "Obtiene la lista de usuarios del sitio con su ID, nombre, email y rol. Útil para asignar autores a posts."
msgstr "Get the list of site users with ID, name, email, and role. Useful for assigning authors to posts."

#: includes/abilities.php:811
msgid "Crea un nuevo post/entrada en el blog. Acepta título, contenido HTML, extracto, categorías, etiquetas, imagen destacada y estado. Por defecto crea como borrador."
msgstr "Create a new blog post. Accepts title, HTML content, excerpt, categories, tags, featured image, and status. Creates as draft by default."

#: includes/abilities.php:965
msgid "Actualiza un post existente. Solo se modifican los campos enviados, los demás permanecen intactos."
msgstr "Update an existing post. Only the provided fields are modified, the rest remain unchanged."

#: includes/abilities.php:1106
msgid "Envía un post a la papelera o lo elimina permanentemente. Por defecto envía a la papelera."
msgstr "Move a post to trash or permanently delete it. Moves to trash by default."

#: includes/abilities.php:1174
msgid "Crea una nueva categoría en el blog con nombre, slug, descripción y categoría padre (opcional)."
msgstr "Create a new blog category with name, slug, description, and parent category (optional)."

#: includes/abilities.php:1257
msgid "Crea una nueva etiqueta (tag) en el blog con nombre, slug y descripción."
msgstr "Create a new blog tag with name, slug, and description."

#: includes/abilities.php:1332
msgid "Crea una nueva página en WordPress con título, contenido, estado y página padre (para jerarquía)."
msgstr "Create a new WordPress page with title, content, status, and parent page (for hierarchy)."

#: includes/abilities.php:1427
msgid "Cambia el estado de un comentario: aprobar, poner en espera, marcar como spam o enviar a la papelera."
msgstr "Change comment status: approve, hold, mark as spam, or move to trash."

#: includes/abilities.php:1509
msgid "Descarga una imagen desde una URL externa y la registra en la biblioteca de medios de WordPress. Opcionalmente puede asignarla como imagen destacada de un post. Retorna el ID del attachment y la URL local."
msgstr "Download an image from an external URL and register it in the WordPress media library. Optionally assign it as a post's featured image. Returns the attachment ID and local URL."

#: includes/abilities.php:1682
msgid "Obtiene toda la metadata SEO de Rank Math para un post o página: título, descripción, keywords, robots, robots avanzados, Open Graph, Twitter Card, schema, breadcrumb, cornerstone y score SEO."
msgstr "Get all Rank Math SEO metadata for a post or page: title, description, keywords, robots, advanced robots, Open Graph, Twitter Card, schema, breadcrumb, cornerstone, and SEO score."

#: includes/abilities.php:1807
msgid "Actualiza la metadata SEO de Rank Math en un post o página (rank_math_focus_keyword, rank_math_title, rank_math_description, etc). Usa esta ability para establecer o cambiar la palabra clave objetivo (focus keyword), título SEO, meta descripción, canonical URL, robots, Open Graph, Twitter Card, breadcrumb, schema snippet, cornerstone y contenido pilar. Solo se modifican los campos enviados."
msgstr "Update Rank Math SEO metadata for a post or page (rank_math_focus_keyword, rank_math_title, rank_math_description, etc). Use this ability to set or change the focus keyword, SEO title, meta description, canonical URL, robots, Open Graph, Twitter Card, breadcrumb, schema snippet, cornerstone, and pillar content. Only the provided fields are modified."

#: includes/abilities.php:2096
msgid "Busca un texto en el contenido de un post específico y lo reemplaza por otro. Útil para correcciones y actualizaciones."
msgstr "Search for text in a specific post's content and replace it. Useful for corrections and updates."

#: includes/abilities.php:2185
msgid "Devuelve un resumen con el total de posts, páginas, categorías, etiquetas, comentarios y usuarios del sitio."
msgstr "Returns a summary with the total posts, pages, categories, tags, comments, and users on the site."

